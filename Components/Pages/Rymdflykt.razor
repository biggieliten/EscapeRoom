                  padding: 18px 18px 16px;
                  box-shadow: 0 0 50px rgba(0, 0, 0, .65);
                  max-width: 440px;
                  margin: 0 auto;
                  display: none;
                  max-height: 76vh;
                  overflow-y: auto;
