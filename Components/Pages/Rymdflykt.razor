                }

                .rf-eyebrow.green {
                  color: var(--green);
                }

                .rf-h1 {
                  font-family: 'Orbitron', sans-serif;
                  font-weight: 900;
                  font-size: clamp(38px, 13vw, 64px);
                  letter-spacing: .04em;
                  line-height: .95;
                  color: #fff;
                  margin-bottom: 22px;
                  text-shadow: 0 0 24px rgba(56, 225, 225, .55), 0 0 60px rgba(56, 225, 225, .25);
                }

