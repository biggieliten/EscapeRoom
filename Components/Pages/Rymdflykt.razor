                  display: flex;
                }

                .rf-topbar {
                  display: grid;
                  grid-template-columns: 1fr auto 1fr;
                  align-items: center;
                  padding: 12px 14px 6px;
                  gap: 8px;
                  flex-shrink: 0;
                }

                .rf-tb {
                  font-family: 'Orbitron', sans-serif;
                  font-size: 10.5px;
                  letter-spacing: .1em;
                  color: var(--txt);
                  background: var(--panel);
                  border: 1px solid var(--border);
                  padding: 9px 12px;
                  border-radius: 10px;
                  cursor: pointer;
                  text-transform: uppercase;
                  white-space: nowrap;
                }

                .rf-tb.left {
                  justify-self: start;
                  color: var(--gold);
                  border-color: rgba(255, 210, 63, .35);
                }

                .rf-tb.right {
                  justify-self: end;
                }

                .rf-timer {
                  font-family: 'Orbitron', sans-serif;
                  font-weight: 700;
                  font-size: 17px;
                  letter-spacing: .08em;
                  color: var(--cyan);
                  justify-self: center;
                  text-shadow: 0 0 12px rgba(56, 225, 225, .4);
                }

                .rf-wrap {
                  position: relative;
                  flex: 1 1 auto;
                  min-height: 0;
                  touch-action: none;
                }

                #rf-scene {
                  width: 100%;
                  height: 100%;
                  display: block;
                }

                .rf-grab {
                  position: absolute;
                  bottom: 8px;
                  left: 0;
                  width: 100%;
                  text-align: center;
                  font-size: 11px;
                  letter-spacing: .14em;
                  color: var(--txt-dim);
                  text-transform: uppercase;
                  font-family: 'Orbitron', sans-serif;
                  pointer-events: none;
                  transition: opacity .5s;
                }

                .rf-console {
                  flex-shrink: 0;
                  background: linear-gradient(180deg, transparent, rgba(4, 5, 14, .7) 22%, var(--bg2));
                  border-top: 1px solid var(--border);
                  padding: 12px 16px calc(14px + env(safe-area-inset-bottom));
                  box-shadow: 0 -12px 40px rgba(56, 225, 225, .08);
                }

                .rf-lead {
                  font-family: 'Orbitron', sans-serif;
                  font-size: 10px;
                  letter-spacing: .14em;
                  text-transform: uppercase;
                  color: var(--txt-dim);
                  text-align: center;
                  margin-bottom: 10px;
                }

                .rf-code {
                  display: flex;
                  justify-content: center;
                  gap: 10px;
                  margin-bottom: 11px;
                }

                .slot {
                  width: 50px;
                  height: 56px;
                  border-radius: 12px;
                  background: rgba(8, 12, 30, .85);
                  border: 1.5px solid var(--border);
                  display: flex;
                  align-items: center;
                  justify-content: center;
